# GLM2API 环境变量配置示例
# 复制此文件为 .env 并修改

# 必填：智谱 refresh token（从 chatglm.cn 获取），多个用逗号分隔
REFRESH_TOKEN=your_refresh_token_here

# 必填：API 密钥（客户端调用时需提供）
API_KEY=your-secret-api-key

# 可选：监听端口（默认 3099）
PORT=3099

# 可选：每个 token 最大并发数（默认 2）
MAX_CONCURRENT_PER_TOKEN=2

# 可选：连续失败次数阈值，达到后标记为 dead（默认 5）
TOKEN_DEAD_THRESHOLD=5

# 可选：健康检查间隔（秒，默认 600）
HEALTH_CHECK_INTERVAL=600

# 可选：日志级别（info/debug，默认 info）
LOG_LEVEL=info

# 可选：管理面板访问密钥（不设置则无需认证）
ADMIN_KEY=your-admin-key
