# GLM 认证（至少配置一项）
DS_TOKENS=
DS_ACCOUNTS=

# API 鉴权密钥（强烈建议设置，留空则不鉴权）
API_KEY=

# 每个令牌最大并发请求数
MAX_CONCURRENT_PER_TOKEN=2

# 连续错误多少次后标记令牌为 dead
TOKEN_DEAD_THRESHOLD=5

# 健康检查间隔（秒）
HEALTH_CHECK_INTERVAL=600

# 仅检查空闲超过此时长的令牌（秒）
IDLE_THRESHOLD=1800

# 会话缓存 TTL（秒）
SESSION_TTL=1800

# 每会话最大请求数
MAX_REQUESTS_PER_SESSION=8

# 是否合并思考内容到输出
MERGE_THINKING=false

# 出站代理（可选）
HTTPS_PROXY=
HTTP_PROXY=
